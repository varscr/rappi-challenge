# Scraping Configuration
RAPPI_BASE_URL=https://www.rappi.com.mx
UBER_EATS_BASE_URL=https://www.ubereats.com
DIDI_FOOD_BASE_URL=https://www.didi-food.com

# DiDi Food Auth (required - get from browser after login)
# 1. Log in at https://www.didi-food.com/es-MX/
# 2. Open DevTools > Application > Local Storage
# 3. Copy the "ticket" value
DIDI_TICKET=

# Data Paths
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed

# Scraping Settings
MAX_RETRIES=3
WAIT_TIME_MIN=5
WAIT_TIME_MAX=15

# Geolocation
GEOPY_USER_AGENT=rappi_competitive_intel
